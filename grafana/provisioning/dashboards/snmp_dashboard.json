            "uid": "MySQL-SNMP"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  FROM_UNIXTIME(FLOOR(UNIX_TIMESTAMP(STR_TO_DATE(timestamp, '%Y-%m-%dT%H:%i:%s.%f')) / 60) * 60) AS time,\n  AVG(anomaly_score) AS anomaly_score\nFROM snmp_metrics_ai\nWHERE\n  UNIX_TIMESTAMP(STR_TO_DATE(timestamp, '%Y-%m-%dT%H:%i:%s.%f')) BETWEEN $__unixEpochFrom() AND $__unixEpochTo()\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "table": "snmp_metrics_ai",
          "timeColumn": "timestamp"
        }
      ],
      "title": "Anomaly Score Over Time",
      "type": "timeseries"
